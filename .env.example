DATABASE_URL=postgresql://user:pass@localhost:5432/travel_together
JWT_SECRET=your-secret-key-here

# OpenAI — required for Whisper transcription and Claude memory/dream structuring
OPENAI_API_KEY=sk-...

# Anthropic — required for Claude location normalization + AI structuring
ANTHROPIC_API_KEY=sk-ant-...

# Unsplash — required for dream pin imagery (https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Google OAuth — required for Google sign-in (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
